{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT u.username, s.current_streak, s.longest_streak, s.total_solved\n        FROM user_stats s\n        JOIN users u ON u.id = s.user_id\n        ORDER BY s.current_streak DESC, s.total_solved DESC\n        LIMIT $1\n        ",
